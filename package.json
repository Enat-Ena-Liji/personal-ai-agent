{"type": "commonjs",
  "name": "personal-ai-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:socket\"",
    "dev:next": "next dev --webpack",
    "dev:socket": "node server.js",
    "build": "next build --webpack",
    "start": "concurrently \"npm run start:next\" \"npm run start:socket\"",
    "start:next": "next start --webpack",
    "start:socket": "node server.js",
    "lint": "next lint",
    "postinstall": "npm run build:convex",
    "build:convex": "npx convex dev --once"
  },
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@clerk/nextjs": "^7.5.10",
    "@clerk/themes": "^1.7.3",
    "@google/generative-ai": "^0.24.1",
    "@hapi/boom": "^10.0.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@slack/web-api": "^7.18.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "axios": "^1.18.1",
    "convex": "^1.42.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "jimp": "^1.6.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/socket.io": "^3.0.1",
    "concurrently": "^8.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}